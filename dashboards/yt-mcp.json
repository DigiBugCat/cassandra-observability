{
  "uid": "yt-mcp-overview",
  "title": "YT-MCP Transcription",
  "tags": [
    "cassandra",
    "yt-mcp"
  ],
  "timezone": "browser",
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "title": "Total Transcriptions",
      "type": "stat",
      "gridPos": {
        "h": 5,
        "w": 5,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(yt_mcp_jobs_total) or vector(0)"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Success Rate",
      "type": "stat",
      "gridPos": {
        "h": 5,
        "w": 5,
        "x": 5,
        "y": 0
      },
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(yt_mcp_jobs_total{status=\"completed\"}) / sum(yt_mcp_jobs_total) or vector(1)"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 1,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "value": null,
                "color": "red"
              },
              {
                "value": 0.8,
                "color": "yellow"
              },
              {
                "value": 0.95,
                "color": "green"
              }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Total Minutes Transcribed",
      "type": "stat",
      "gridPos": {
        "h": 5,
        "w": 5,
        "x": 10,
        "y": 0
      },
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(yt_mcp_audio_duration_seconds_sum) / 60 or vector(0)"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "min",
          "decimals": 0,
          "color": {
            "mode": "fixed",
            "fixedColor": "purple"
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Avg Speed (x realtime)",
      "type": "stat",
      "gridPos": {
        "h": 5,
        "w": 5,
        "x": 15,
        "y": 0
      },
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "expr": "yt_mcp_speed_ratio_sum / yt_mcp_speed_ratio_count or vector(0)"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "decimals": 1,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "value": null,
                "color": "red"
              },
              {
                "value": 3,
                "color": "yellow"
              },
              {
                "value": 5,
                "color": "green"
              }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Stored Transcripts",
      "type": "stat",
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 20,
        "y": 0
      },
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "expr": "yt_mcp_transcripts_stored or vector(0)"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "green"
          }
        }
      }
    },
    {
      "id": 10,
      "title": "",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 5
      },
      "panels": []
    },
    {
      "id": 11,
      "title": "Jobs Over Time (Completed vs Failed)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 6
      },
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(yt_mcp_jobs_total{status=\"completed\"}[5m]))",
          "legendFormat": "completed"
        },
        {
          "expr": "sum(rate(yt_mcp_jobs_total{status=\"failed\"}[5m]))",
          "legendFormat": "failed"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "fillOpacity": 15,
            "lineWidth": 2
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "failed"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "red"
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": 12,
      "title": "Queue Depth & In-Progress",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 6
      },
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "expr": "yt_mcp_jobs_queued",
          "legendFormat": "queued"
        },
        {
          "expr": "yt_mcp_jobs_in_progress{phase=\"downloading\"}",
          "legendFormat": "downloading"
        },
        {
          "expr": "yt_mcp_jobs_in_progress{phase=\"transcribing\"}",
          "legendFormat": "transcribing"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 2,
            "stacking": {
              "mode": "normal"
            }
          }
        }
      }
    },
    {
      "id": 20,
      "title": "",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 14
      },
      "panels": []
    },
    {
      "id": 21,
      "title": "Transcription Duration (p50 / p90 / p99)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 15
      },
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(yt_mcp_transcription_duration_seconds_bucket[30m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.90, sum(rate(yt_mcp_transcription_duration_seconds_bucket[30m])) by (le))",
          "legendFormat": "p90"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(yt_mcp_transcription_duration_seconds_bucket[30m])) by (le))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 22,
      "title": "Speed Ratio Over Time (x realtime)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 15
      },
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(yt_mcp_speed_ratio_bucket[30m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.90, sum(rate(yt_mcp_speed_ratio_bucket[30m])) by (le))",
          "legendFormat": "p90"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 1,
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 23,
      "title": "Download Duration (p50 / p90 / p99)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 15
      },
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(yt_mcp_download_duration_seconds_bucket[30m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.90, sum(rate(yt_mcp_download_duration_seconds_bucket[30m])) by (le))",
          "legendFormat": "p90"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(yt_mcp_download_duration_seconds_bucket[30m])) by (le))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 30,
      "title": "",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 23
      },
      "panels": []
    },
    {
      "id": 31,
      "title": "Audio Duration Distribution",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 24
      },
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(yt_mcp_audio_duration_seconds_bucket[1h])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.90, sum(rate(yt_mcp_audio_duration_seconds_bucket[1h])) by (le))",
          "legendFormat": "p90"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 32,
      "title": "Word Count Distribution",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 24
      },
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(yt_mcp_word_count_bucket[1h])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.90, sum(rate(yt_mcp_word_count_bucket[1h])) by (le))",
          "legendFormat": "p90"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 33,
      "title": "Speaker Count Distribution",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 24
      },
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(yt_mcp_speaker_count_bucket[1h])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.90, sum(rate(yt_mcp_speaker_count_bucket[1h])) by (le))",
          "legendFormat": "p90"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 40,
      "title": "",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 32
      },
      "panels": []
    },
    {
      "id": 41,
      "title": "Transcriber Usage (Local vs AssemblyAI)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 33
      },
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(yt_mcp_jobs_total{transcriber=\"local\"}[30m]))",
          "legendFormat": "local GPU"
        },
        {
          "expr": "sum(rate(yt_mcp_jobs_total{transcriber=\"assemblyai\"}[30m]))",
          "legendFormat": "AssemblyAI"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 2,
            "stacking": {
              "mode": "normal"
            }
          }
        }
      }
    },
    {
      "id": 42,
      "title": "Fallback Triggers & Retries",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 33
      },
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(yt_mcp_fallback_total[30m])) by (reason)",
          "legendFormat": "fallback: {{reason}}"
        },
        {
          "expr": "sum(rate(yt_mcp_retries_total[30m]))",
          "legendFormat": "retries"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 43,
      "title": "API Request Rate",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 33
      },
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(yt_mcp_api_requests_total[5m])) by (endpoint)",
          "legendFormat": "{{endpoint}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 44,
      "title": "API Latency (p50 / p90 / p99)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 41
      },
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(yt_mcp_api_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.90, sum(rate(yt_mcp_api_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p90"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(yt_mcp_api_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2
          }
        }
      }
    }
  ],
  "schemaVersion": 39
}
