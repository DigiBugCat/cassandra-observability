{
  "uid": "workers-overview",
  "title": "Workers & MCP",
  "tags": ["cassandra", "workers"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "" },
        "query": "label_values(mcp_requests_total, service)",
        "current": { "text": "All", "value": "$__all" },
        "includeAll": true,
        "multi": false,
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Total Requests",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus" },
      "targets": [{ "expr": "sum(mcp_requests_total{service=~\"$service\"}) or vector(0)" }],
      "options": { "colorMode": "background", "graphMode": "area", "textMode": "value" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "blue" } } }
    },
    {
      "id": 2,
      "title": "Error Rate (4xx/5xx)",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus" },
      "targets": [{ "expr": "sum(mcp_requests_total{service=~\"$service\", status=~\"4..|5..\"}) / sum(mcp_requests_total{service=~\"$service\"}) or vector(0)" }],
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "decimals": 2, "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "value": null, "color": "green" }, { "value": 0.01, "color": "yellow" }, { "value": 0.05, "color": "red" }] } } }
    },
    {
      "id": 3,
      "title": "Active MCP Keys",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus" },
      "targets": [{ "expr": "sum(mcp_active_keys) or vector(0)" }],
      "options": { "colorMode": "background", "graphMode": "area", "textMode": "value" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "purple" } } }
    },
    {
      "id": 4,
      "title": "Key Operations",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus" },
      "targets": [{ "expr": "sum(mcp_key_operations_total) or vector(0)" }],
      "options": { "colorMode": "background", "graphMode": "area", "textMode": "value" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "orange" } } }
    },
    {
      "id": 10,
      "title": "",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "panels": []
    },
    {
      "id": 11,
      "title": "Request Rate by Service",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus" },
      "targets": [
        { "expr": "sum(rate(mcp_requests_total{service=~\"$service\"}[5m])) by (service)", "legendFormat": "{{service}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "fillOpacity": 15, "lineWidth": 2 } } }
    },
    {
      "id": 12,
      "title": "Error Rate by Service",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus" },
      "targets": [
        { "expr": "sum(rate(mcp_requests_total{service=~\"$service\", status=~\"4..|5..\"}[5m])) by (service, status)", "legendFormat": "{{service}} {{status}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "fillOpacity": 10, "lineWidth": 2 }, "color": { "mode": "palette-classic" } } }
    },
    {
      "id": 20,
      "title": "",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "panels": []
    },
    {
      "id": 21,
      "title": "Requests by Status Code",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "datasource": { "type": "prometheus" },
      "targets": [
        { "expr": "sum(rate(mcp_requests_total{service=~\"$service\"}[5m])) by (status)", "legendFormat": "{{status}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "fillOpacity": 15, "lineWidth": 2, "stacking": { "mode": "normal" } } } }
    },
    {
      "id": 22,
      "title": "Key CRUD Operations",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "datasource": { "type": "prometheus" },
      "targets": [
        { "expr": "sum(rate(mcp_key_operations_total[5m])) by (operation)", "legendFormat": "{{operation}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "fillOpacity": 15, "lineWidth": 2 } } }
    },
    {
      "id": 30,
      "title": "",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "panels": []
    },
    {
      "id": 31,
      "title": "Requests by API Key",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus" },
      "targets": [
        { "expr": "sum(rate(mcp_requests_total{service=~\"$service\"}[5m])) by (key_name)", "legendFormat": "{{key_name}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "fillOpacity": 15, "lineWidth": 2 } } }
    },
    {
      "id": 32,
      "title": "Requests by Path",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus" },
      "targets": [
        { "expr": "sum(mcp_requests_total{service=~\"$service\"}) by (path)", "legendFormat": "{{path}}" }
      ],
      "options": { "legend": { "placement": "right", "displayMode": "table", "values": ["value"] }, "pieType": "donut" }
    }
  ],
  "schemaVersion": 39
}
