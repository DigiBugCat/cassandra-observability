{
  "uid": "agent-sessions",
  "title": "Agent Sessions",
  "tags": [
    "cassandra"
  ],
  "timezone": "browser",
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "namespace",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": ""
        },
        "query": "label_values(sessions_created_total, namespace)",
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "includeAll": true,
        "multi": false,
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Active Sessions",
      "type": "stat",
      "gridPos": {
        "h": 5,
        "w": 5,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(sessions_active{namespace=~\"$namespace\"}) or vector(0)"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "green"
          },
          "thresholds": {
            "steps": [
              {
                "value": null,
                "color": "green"
              },
              {
                "value": 5,
                "color": "yellow"
              },
              {
                "value": 10,
                "color": "red"
              }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Total Sessions",
      "type": "stat",
      "gridPos": {
        "h": 5,
        "w": 5,
        "x": 5,
        "y": 0
      },
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(sessions_created_total{namespace=~\"$namespace\"}) or vector(0)"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          },
          "thresholds": {
            "steps": [
              {
                "value": null,
                "color": "blue"
              }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Warm Pool Hit Rate",
      "type": "stat",
      "gridPos": {
        "h": 5,
        "w": 5,
        "x": 10,
        "y": 0
      },
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(warm_pool_hits_total{namespace=~\"$namespace\"}) / (sum(warm_pool_hits_total{namespace=~\"$namespace\"}) + sum(warm_pool_misses_total{namespace=~\"$namespace\"}))"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "value": null,
                "color": "red"
              },
              {
                "value": 0.5,
                "color": "yellow"
              },
              {
                "value": 0.8,
                "color": "green"
              }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Total Cost (USD)",
      "type": "stat",
      "gridPos": {
        "h": 5,
        "w": 5,
        "x": 15,
        "y": 0
      },
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(cost_usd_total{namespace=~\"$namespace\"}) or vector(0)"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2,
          "color": {
            "mode": "fixed",
            "fixedColor": "orange"
          },
          "thresholds": {
            "steps": [
              {
                "value": null,
                "color": "orange"
              }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Total Tokens",
      "type": "stat",
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 20,
        "y": 0
      },
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(tokens_consumed_total{namespace=~\"$namespace\"}) or vector(0)"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "fixed",
            "fixedColor": "purple"
          },
          "thresholds": {
            "steps": [
              {
                "value": null,
                "color": "purple"
              }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 5
      },
      "panels": []
    },
    {
      "id": 7,
      "title": "Sessions Created Over Time",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 6
      },
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(sessions_created_total{namespace=~\"$namespace\"}[5m])) by (model)",
          "legendFormat": "{{model}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 8,
      "title": "Active Sessions by Status",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 6
      },
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(sessions_active{namespace=~\"$namespace\"}) by (status)",
          "legendFormat": "{{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 2,
            "stacking": {
              "mode": "normal"
            }
          }
        }
      }
    },
    {
      "id": 9,
      "title": "",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 14
      },
      "panels": []
    },
    {
      "id": 10,
      "title": "Message Response Time",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 15
      },
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(message_duration_seconds_bucket{namespace=~\"$namespace\"}[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.90, sum(rate(message_duration_seconds_bucket{namespace=~\"$namespace\"}[5m])) by (le))",
          "legendFormat": "p90"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(message_duration_seconds_bucket{namespace=~\"$namespace\"}[5m])) by (le))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 11,
      "title": "Spawn Duration",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 15
      },
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(spawn_duration_seconds_bucket{namespace=~\"$namespace\"}[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.90, sum(rate(spawn_duration_seconds_bucket{namespace=~\"$namespace\"}[5m])) by (le))",
          "legendFormat": "p90"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(spawn_duration_seconds_bucket{namespace=~\"$namespace\"}[5m])) by (le))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 12,
      "title": "",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 23
      },
      "panels": []
    },
    {
      "id": 13,
      "title": "Token Consumption Rate",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 24
      },
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(tokens_consumed_total{namespace=~\"$namespace\", type=\"input\"}[5m]))",
          "legendFormat": "input"
        },
        {
          "expr": "sum(rate(tokens_consumed_total{namespace=~\"$namespace\", type=\"output\"}[5m]))",
          "legendFormat": "output"
        },
        {
          "expr": "sum(rate(tokens_consumed_total{namespace=~\"$namespace\", type=\"cache_read\"}[5m]))",
          "legendFormat": "cache read"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "fillOpacity": 15,
            "lineWidth": 2,
            "stacking": {
              "mode": "normal"
            }
          }
        }
      }
    },
    {
      "id": 14,
      "title": "Cost Rate (USD/min)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 24
      },
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(cost_usd_total{namespace=~\"$namespace\"}[5m])) by (model) * 60",
          "legendFormat": "{{model}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 4,
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 2,
            "stacking": {
              "mode": "normal"
            }
          }
        }
      }
    },
    {
      "id": 15,
      "title": "",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 32
      },
      "panels": []
    },
    {
      "id": 16,
      "title": "Runner Errors",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 33
      },
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(runner_errors_total{namespace=~\"$namespace\"}[5m])) by (error_code)",
          "legendFormat": "{{error_code}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2
          },
          "color": {
            "mode": "palette-classic"
          }
        }
      }
    },
    {
      "id": 17,
      "title": "Compactions Triggered",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 33
      },
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(compactions_total{namespace=~\"$namespace\"}[5m])) by (trigger)",
          "legendFormat": "{{trigger}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "fillOpacity": 15,
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 18,
      "title": "Warm Pool Size",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 41
      },
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "expr": "warm_pool_size{namespace=~\"$namespace\"}",
          "legendFormat": "{{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 2,
            "stacking": {
              "mode": "normal"
            }
          }
        }
      }
    },
    {
      "id": 19,
      "title": "WebSocket Connections",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 41
      },
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "expr": "ws_connections_active{namespace=~\"$namespace\"}",
          "legendFormat": "{{pod}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 2
          }
        }
      }
    }
  ],
  "schemaVersion": 39
}
