{
  "uid": "orchestrator-overview",
  "title": "Orchestrator Overview",
  "tags": [
    "cassandra"
  ],
  "timezone": "browser",
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "namespace",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": ""
        },
        "query": "label_values(api_requests_total, namespace)",
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "includeAll": true,
        "multi": false,
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "API Request Rate",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(api_requests_total{namespace=~\"$namespace\"}[5m])) by (path, method)",
          "legendFormat": "{{method}} {{path}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Error Rate (non-2xx)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(api_requests_total{namespace=~\"$namespace\", status!~\"2..\"}[5m])) by (path, status)",
          "legendFormat": "{{status}} {{path}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2
          },
          "color": {
            "mode": "palette-classic"
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Request Latency p50 / p90 / p99",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(api_request_duration_seconds_bucket{namespace=~\"$namespace\"}[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.90, sum(rate(api_request_duration_seconds_bucket{namespace=~\"$namespace\"}[5m])) by (le))",
          "legendFormat": "p90"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(api_request_duration_seconds_bucket{namespace=~\"$namespace\"}[5m])) by (le))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "fillOpacity": 5,
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Sessions Created",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(sessions_created_total{namespace=~\"$namespace\"}[5m])) by (namespace)",
          "legendFormat": "{{namespace}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Total Requests by Status",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 24,
        "x": 0,
        "y": 16
      },
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(api_requests_total{namespace=~\"$namespace\"}) by (status)",
          "legendFormat": "HTTP {{status}}"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name"
      }
    },
    {
      "id": 6,
      "title": "Requests by Path",
      "type": "piechart",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 20
      },
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(api_requests_total{namespace=~\"$namespace\"}) by (path)",
          "legendFormat": "{{path}}"
        }
      ]
    },
    {
      "id": 7,
      "title": "Active Connections (Traefik)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 20
      },
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(traefik_open_connections) by (entrypoint)",
          "legendFormat": "{{entrypoint}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 15,
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 8,
      "title": "Warm Pool Hit / Miss Rate",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 28
      },
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "expr": "rate(warm_pool_hits_total{namespace=~\"$namespace\"}[5m])",
          "legendFormat": "hits"
        },
        {
          "expr": "rate(warm_pool_misses_total{namespace=~\"$namespace\"}[5m])",
          "legendFormat": "misses (cold spawn)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "fillOpacity": 15,
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 9,
      "title": "Token Pool Usage",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 28
      },
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "expr": "token_pool_usage{namespace=~\"$namespace\"}",
          "legendFormat": "token #{{token_index}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 15,
            "lineWidth": 2,
            "stacking": {
              "mode": "normal"
            }
          }
        }
      }
    }
  ],
  "schemaVersion": 39
}
